---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9 http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd" xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% assign pages = site.pages | where_exp: "page", "page.sitemap != false" | where_exp: "page", "page.url != '/404.html'" %}
  {% for page in pages %}
  <url>
    <loc>{{ page.url | absolute_url | xml_escape }}</loc>
  </url>
  {% endfor %}
  {% assign collections = site.collections | where_exp: "col", "col.label != 'posts'" %}
  {% for collection in collections %}
  {% assign docs = collection.docs | where_exp: "doc", "doc.sitemap != false" %}
  {% for doc in docs %}
  <url>
    <loc>{{ doc.url | absolute_url | xml_escape }}</loc>
  </url>
  {% endfor %}
  {% endfor %}
  {% for post in site.posts %}
  {% unless post.sitemap == false %}
  <url>
    <loc>{{ post.url | absolute_url | xml_escape }}</loc>
  </url>
  {% endunless %}
  {% endfor %}
</urlset>
